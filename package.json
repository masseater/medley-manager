{
  "name": "medley-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web \"tsx watch src/server/index.ts\" \"npm --prefix web run dev\"",
    "build": "npm --prefix web run build",
    "start": "tsx src/server/index.ts",
    "mcp": "tsx src/mcp/index.ts",
    "typecheck": "tsc --noEmit && npm --prefix web run typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.6.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
