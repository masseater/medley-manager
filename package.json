{
  "name": "medley-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "concurrently -n server,web \"tsx watch src/server/index.ts\" \"pnpm -C web dev\"",
    "build": "pnpm -C web build",
    "start": "tsx src/server/index.ts",
    "mcp": "tsx src/mcp/index.ts",
    "test": "vitest run",
    "knip": "knip",
    "typecheck": "tsc --noEmit && pnpm -C web typecheck"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.1",
    "hono": "^4.6.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "knip": "^6.27.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
